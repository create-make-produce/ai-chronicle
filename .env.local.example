# =============================================
# AI Chronicle - 環境変数テンプレート
# =============================================
# このファイルは .gitignore に追加済み・GitHubには絶対に上げない
# 実際のAPIキーをここに記入する
# =============================================

# --- AIプロバイダー（config.tsのAI_PROVIDERに合わせる） ---
# Gemini使用時：
AI_API_KEY=your_gemini_key_here
# OpenAI使用時：
# AI_API_KEY=your_openai_key_here
# Claude使用時：
# AI_API_KEY=your_anthropic_key_here

# --- Product Hunt API ---
# 取得先: https://www.producthunt.com/v2/oauth/applications
# Client Credentials方式でアクセストークンを取得するため、KeyとSecretの両方が必要
PRODUCT_HUNT_API_KEY=your_product_hunt_key_here
PRODUCT_HUNT_API_SECRET=your_product_hunt_secret_here

# --- Cloudflare ---
# 取得先: https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_D1_DATABASE_ID=your_database_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# --- サイト設定（公開しても問題ない値） ---
NEXT_PUBLIC_SITE_URL=https://ai-chronicle.com
# 開発時は http://localhost:3000 でOK
